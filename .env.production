# Must be a .bxiworld.com host so the shared `jwt` cookie (Domain=.bxiworld.com,
# set at app.bxiworld.com) is sent with credentialed requests. Pointing this at a
# bxiworld.in host means the browser never attaches the cookie -> AuthGuard sees
# the user as logged out and redirects back to app.bxiworld.com.
REACT_APP_API_URL=https://api-production.bxiworld.com
REACT_APP_DASHBOARD_URL=https://app.bxiworld.com
REACT_APP_ADMIN_URL=https://admin.bxiworld.com
REACT_APP_LOGIN_URL=https://app.bxiworld.com
